# Azure SQL / SQL Server for Prisma (JDBC-style)
# Format: sqlserver://HOST:1433;database=DB;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=false
DATABASE_URL="sqlserver://YOURSERVER.database.windows.net:1433;database=crmflow;user=crmadmin;password={REPLACE_ME};encrypt=true;trustServerCertificate=false"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-32+chars-random"

# App
APP_NAME="CRMFlow"
